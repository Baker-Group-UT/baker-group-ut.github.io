---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-crust-200/80 bg-crust-100/40
               dark:border-crust-800/80 dark:bg-crust-900/60 transition-colors">
  <div class="container-page py-12 grid gap-10 md:grid-cols-[1.3fr_1fr_1fr]">
    <div>
      <p class="font-serif text-xl text-crust-900 dark:text-crust-50">The Baker Group</p>
      <p class="mt-2 text-sm leading-relaxed text-crust-700 dark:text-crust-300 max-w-sm">
        Research on fault-tolerant quantum computer architecture at
        The University of Texas at Austin.
      </p>
    </div>

    <div>
      <p class="eyebrow">Visit</p>
      <address class="mt-3 not-italic text-sm leading-relaxed text-crust-700 dark:text-crust-300">
        Department of Electrical &amp; Computer Engineering<br />
        The University of Texas at Austin<br />
        2501 Speedway, Austin, TX 78712
      </address>
    </div>

    <div>
      <p class="eyebrow">Connect</p>
      <ul class="mt-3 space-y-1.5 text-sm">
        <li><a class="link-burnt" href="mailto:jonathan.baker@austin.utexas.edu">jonathan.baker@austin.utexas.edu</a></li>
        <li><a class="link-burnt" href="https://scholar.google.com/citations?user=87cLl3gAAAAJ">Google Scholar</a></li>
        <li><a class="link-burnt" href="https://github.com/Baker-Group-UT">GitHub</a></li>
        <li><a class="link-burnt" href="/rss.xml">RSS</a></li>
      </ul>
    </div>
  </div>

  <div class="divider-wheat"></div>

  <div class="container-page py-6">
    <p class="text-xs text-crust-600 dark:text-crust-400">
      &copy; {year} The Baker Group. The University of Texas at Austin.
    </p>
  </div>
</footer>

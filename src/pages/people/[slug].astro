---
import BaseLayout from "@layouts/BaseLayout.astro";
import PublicationItem from "@components/PublicationItem.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import {
  comparePublications,
  dedupePublications,
  pubHasAuthor,
} from "@lib/publications";

export async function getStaticPaths() {
  const people = await getCollection("people");
  return people.map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }));
}

interface Props {
  person: CollectionEntry<"people">;
}

const { person } = Astro.props;
const { Content } = await person.render();

// All the name variants this person publishes under. The main name is
// stripped of honorifics so "Prof. Jonathan M. Baker" matches OpenAlex's
// "Jonathan M. Baker"; aliases are used as-is.
const myNames = [
  person.data.name.replace(/^(Prof\.|Dr\.|Mr\.|Ms\.|Mrs\.)\s+/, ""),
  ...(person.data.aliases ?? []),
];

// Papers this person co-authored: match by name appearance in the paper's
// author list (rather than relying on OpenAlex having linked every
// authorship back to the canonical author ID).
const allPubs = await getCollection("publications");
const mine = dedupePublications(
  allPubs.filter((p) => pubHasAuthor(p, myNames)),
).sort(comparePublications);

// Deterministic warm-palette swatch for placeholder avatars (same as
// PersonCard so the profile page and card feel consistent).
const swatches = [
  "from-butter-200 to-crust-300 dark:from-butter-400 dark:to-crust-700",
  "from-crust-200 to-burnt-200 dark:from-crust-700 dark:to-burnt-800",
  "from-burnt-100 to-crust-300 dark:from-burnt-900 dark:to-crust-700",
  "from-butter-300 to-burnt-200 dark:from-butter-500 dark:to-burnt-800",
  "from-sage-100 to-crust-200 dark:from-sage-500 dark:to-crust-800",
];
const swatch =
  swatches[
    [...person.data.name].reduce((acc, c) => acc + c.charCodeAt(0), 0) %
      swatches.length
  ];
const initials = person.data.name
  .split(" ")
  .map((p) => p[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();

const hasLinks =
  person.data.email ||
  person.data.website ||
  person.data.github ||
  person.data.scholar;

// Split the bio into paragraphs on blank lines so `\n\n` inside the quoted
// YAML string renders as a real paragraph break instead of collapsing to a
// space inside a single <p>.
const bioParagraphs = (person.data.bio ?? "")
  .split(/\n\s*\n/)
  .map((s) => s.trim())
  .filter(Boolean);

// Oversize-and-anchor (same as PersonCard/PIFeatureCard): the image is
// taller than its circular frame by the shift extent, so translating it
// reframes the crop instead of sliding the avatar out of its frame.
//
// image_y_shift is a pixel value people tune against the /people grid
// card, whose square photo renders at roughly 220px. This avatar is 96px
// (h-24), so carry the shift over proportionally — using the raw pixel
// value here would over-shift by ~2x. image_zoom is a pure multiplier
// and carries over unchanged.
const AVATAR_SHIFT_SCALE = 96 / 220;
const yShift = Math.round(person.data.image_y_shift * AVATAR_SHIFT_SCALE);
const zoom = person.data.image_zoom;
const transforms = [
  yShift !== 0 ? `translateY(${yShift}px)` : undefined,
  zoom !== 1 ? `scale(${zoom})` : undefined,
]
  .filter(Boolean)
  .join(" ");
const imageStyle = [
  `height: calc(100% + ${Math.abs(yShift)}px)`,
  yShift > 0 ? `top: -${yShift}px` : "top: 0",
  transforms ? `transform: ${transforms}` : undefined,
  transforms ? "transform-origin: center center" : undefined,
]
  .filter(Boolean)
  .join("; ");
---

<BaseLayout
  title={`${person.data.name} — The Baker Group`}
  description={
    person.data.bio?.replace(/\s+/g, " ").trim() ||
    `${person.data.name}, ${person.data.role} in The Baker Group at UT Austin.`
  }
>
  <section class="container-narrow py-16">
    <a href="/people" class="inline-flex items-center gap-2 text-sm link-burnt">
      <span aria-hidden="true">&larr;</span>
      Back to people
    </a>

    <header class="mt-6 flex flex-col sm:flex-row gap-6 items-start">
      <div class="shrink-0">
        {
          person.data.image ? (
            <div
              class="relative h-24 w-24 rounded-full overflow-hidden ring-1
                     ring-crust-600/20 dark:ring-crust-100/15"
            >
              <img
                src={person.data.image}
                alt={`Portrait of ${person.data.name}`}
                class="absolute left-0 w-full object-cover block"
                style={imageStyle}
                loading="lazy"
              />
            </div>
          ) : (
            <div
              class:list={[
                "h-24 w-24 rounded-full bg-gradient-to-br",
                swatch,
                "grid place-items-center font-serif text-2xl",
                "text-crust-900 dark:text-crust-50",
                "ring-1 ring-crust-600/20 dark:ring-crust-500/30",
              ]}
              aria-hidden="true"
            >
              {initials}
            </div>
          )
        }
      </div>

      <div class="flex-1 min-w-0">
        <p class="eyebrow">
          {person.data.year ? `${person.data.role} · ${person.data.year}` : person.data.role}
        </p>
        <h1
          class="mt-1 font-serif text-4xl sm:text-5xl tracking-tight text-balance
                 text-crust-900 dark:text-crust-50"
        >
          {person.data.name}
        </h1>
        {
          /* Blank lines in the frontmatter `bio` (literal \n\n inside the
             quoted YAML string) become paragraph breaks. */
          bioParagraphs.length > 0 && (
            <div class="mt-3 space-y-3">
              {bioParagraphs.map((para) => (
                <p
                  class="text-lg text-crust-700 dark:text-crust-300 text-pretty"
                  set:html={para}
                />
              ))}
            </div>
          )
        }

        {
          hasLinks && (
            <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm">
              {person.data.email && (
                <li>
                  <a class="link-burnt" href={`mailto:${person.data.email}`}>
                    Email
                  </a>
                </li>
              )}
              {person.data.website && (
                <li>
                  <a class="link-burnt" href={person.data.website}>
                    Website
                  </a>
                </li>
              )}
              {person.data.github && (
                <li>
                  <a class="link-burnt" href={person.data.github}>
                    GitHub
                  </a>
                </li>
              )}
              {person.data.scholar && (
                <li>
                  <a class="link-burnt" href={person.data.scholar}>
                    Scholar
                  </a>
                </li>
              )}
            </ul>
          )
        }
      </div>
    </header>

    <div class="prose dark:prose-invert max-w-none font-sans mt-10">
      <Content />
    </div>

    {
      !person.data.hide_publications && (
        <>
          <hr class="my-12 border-crust-200 dark:border-crust-800" />

          <div class="flex items-baseline gap-3 mb-6">
            <h2 class="font-serif text-2xl text-crust-900 dark:text-crust-50">
              Publications
            </h2>
            <span class="font-mono text-xs text-crust-500 dark:text-crust-400 tabular-nums">
              {mine.length} paper{mine.length === 1 ? "" : "s"}
            </span>
          </div>

          {mine.length === 0 ? (
            <p class="text-sm text-crust-700 dark:text-crust-300 leading-relaxed">
              No publications tagged to this profile yet.
              {person.data.openalex_id ? (
                <span> Papers will appear after the next monthly sync.</span>
              ) : (
                <span>
                  {" "}Add an <code class="font-mono text-burnt-700 dark:text-burnt-300">openalex_id</code>
                  {" "}to this person's frontmatter to enable automatic syncing —
                  see the project README.
                </span>
              )}
            </p>
          ) : (
            <ol>
              {mine.map((p) => (
                <PublicationItem
                  title={p.data.title}
                  authors={p.data.authors}
                  venue={p.data.venue}
                  year={p.data.year}
                  pdf={p.data.pdf}
                  arxiv={p.data.arxiv}
                  doi={p.data.doi}
                  code={p.data.code}
                  highlight={p.data.highlight}
                  badge={p.data.badge}
                  boldNames={myNames}
                />
              ))}
            </ol>
          )}
        </>
      )
    }
  </section>
</BaseLayout>

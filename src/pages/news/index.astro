---
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsCard from "@components/NewsCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("news", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="News — The Baker Group"
  description="Recent news, awards, and updates from The Baker Group."
>
  <section class="container-page py-16">
    <h1 class="sr-only">News</h1>
    {
      posts.length === 0 ? (
        <p class="text-crust-700 dark:text-crust-300">
          No news yet — check back soon.
        </p>
      ) : (
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <NewsCard
              title={post.data.title}
              date={post.data.date}
              summary={post.data.summary}
              tag={post.data.tag}
              href={`/news/${post.slug}`}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
